## 环境变量配置说明 - 复制此文件为 .env 并填入真实值
## cp .env.example .env

# ===== 大模型 API =====
# 选择使用哪个大模型（gemini / deepseek / minimax）
LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=your_deepseek_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 机主 Telegram User ID（从 @userinfobot 获取），0 表示不限制
OWNER_USER_ID=0

# ===== 新闻 =====
GNEWS_API_KEY=your_gnews_api_key_here

# ===== RAG 向量模型（修改后需重新运行 build_index.py）=====
# 可选值：
#   intfloat/multilingual-e5-base   (推荐，2C2G 服务器)
#   intfloat/multilingual-e5-large  (高精度，需 ~1.5GB RAM)
#   BAAI/bge-m3                     (旗舰，需 ~2.3GB RAM)
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# ===== 切片配置（可选，有默认值）=====
# CHUNK_SIZE=800
# CHUNK_OVERLAP=120
